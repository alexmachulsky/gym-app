# PostgreSQL
POSTGRES_DB=gym_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/gym_tracker
SECRET_KEY=change-this-secret-in-real-env
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI (optional — leave blank to disable AI features)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Stripe billing (optional — leave blank to disable billing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=

# Email — Resend (optional — leave blank to disable transactional emails)
RESEND_API_KEY=
FROM_EMAIL=noreply@example.com

# App URL (used in email links and Stripe redirects)
APP_URL=http://localhost:5173

# Sentry (optional — leave blank to disable error tracking)
SENTRY_DSN=

# Frontend
VITE_API_BASE_URL=/api
