apiVersion: v1
kind: Secret
metadata:
  name: gym-secrets
  namespace: gym
type: Opaque
stringData:
  SECRET_KEY: "replace-with-a-long-random-secret"
  DATABASE_URL: "postgresql+psycopg://user:password@gym-postgres:5432/gym_tracker"
  STRIPE_SECRET_KEY: ""
  STRIPE_WEBHOOK_SECRET: ""
  STRIPE_PUBLISHABLE_KEY: ""
  STRIPE_PRO_MONTHLY_PRICE_ID: ""
  STRIPE_PRO_YEARLY_PRICE_ID: ""
  RESEND_API_KEY: ""
  GROQ_API_KEY: ""
  SENTRY_DSN: ""
